# Copiar a .streamlit/secrets.toml en el proyecto Antigravity / Streamlit

[supabase]
url = "https://YOUR_PROJECT.supabase.co"
key = "YOUR_SERVICE_ROLE_OR_ANON_KEY"
# Connection string (Settings → Database → URI). Preferir pooler Transaction mode :6543
database_url = "postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres"
