{
  "name": "casa-inteligente",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:any": "next dev",
    "dev:reset": "powershell -ExecutionPolicy Bypass -File scripts/reset-dev.ps1",
    "ports:free": "powershell -ExecutionPolicy Bypass -File scripts/kill-dev-ports.ps1",
    "dev:fresh": "npm run ports:free && npm run clean:next && npm run dev",
    "clean:next": "node scripts/clean-next.mjs",
    "build": "next build",
    "build:fresh": "node scripts/clean-next.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "verify:supabase": "node scripts/verify-supabase.mjs",
    "verify:db": "node scripts/verify-db.mjs",
    "verify:ci-empleados": "node scripts/verify-ci-empleados.mjs",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-pdf/renderer": "^4.3.2",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^11.18.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "next": "^14.2.0",
    "postgres": "^3.4.8",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "recharts": "^3.8.0",
