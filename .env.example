NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Nexus Home (Drizzle ORM) — misma base PostgreSQL que Supabase: Settings → Database → Connection string (URI)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Reclutamiento inteligente (Gemini; sesiones en PostgreSQL si DATABASE_URL existe, si no memoria en dev)
GEMINI_API_KEY=
# Opcional: POST JSON { phone?, sessionId, reason } al cerrar por tiempo o fraude
RECRUITMENT_WHATSAPP_WEBHOOK_URL=

# Protege dashboard CEO y GET /api/recruitment/result/* (Bearer, ?key= o cookie tras POST /api/recruitment/ceo-auth)
RECRUITMENT_CEO_SECRET=

# true = también permitir acceso CEO si hay sesión Supabase (auth.getUser()) además de la clave anterior
RECRUITMENT_ALLOW_SUPABASE_USER=
