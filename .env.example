NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Solo desarrollo local si Node muestra "unable to verify the first certificate" (antivirus/proxy en Windows):
# SUPABASE_DEV_INSECURE_TLS=1
# Alternativa: npm run dev:tls  (no subir esto a producción)
# Bolívares por 1 USD (Dólar Oficial BCV). Usar en pantallas para equivalente del bono express en Bs; actualizar el día de pago (p. ej. viernes).
NEXT_PUBLIC_TASA_BCV_VES_POR_USD=
# Solo servidor (APIs admin: captación, PDFs, etc.). Supabase → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=
# Si conectaste Supabase desde Vercel (Marketplace), a veces solo existe esta; el código la acepta como alias:
# SUPABASE_SECRET_KEY=
# Alias opcional raro en plantillas:
# SUPABASE_SERVICE_KEY=
# URL pública del sitio (sin barra final), para armar el enlace del examen
NEXT_PUBLIC_BASE_URL=https://tu-dominio.com
# Origen de enlaces /registro?prj=&role= (WhatsApp / copiar en RRHH). Si se omite, se usa NEXT_PUBLIC_BASE_URL o https://casainteligente.company
NEXT_PUBLIC_REGISTRO_ORIGEN=https://casainteligente.company
# Opcional: URL absoluta del listado express (legacy fast-list en otro deployment). Si se omite, la app usa el valor por defecto en `lib/talento/hrefListaContratosExpress.ts`.
# NEXT_PUBLIC_TALENTO_EXPRESS_LIST_URL=https://tu-preview.vercel.app/talento/admin/contratos/fast-list
# Opcional: si se define, POST generar-link exige Authorization: Bearer <este valor>
TALENTO_GENERAR_LINK_SECRET=

# Nexus Home (Drizzle ORM) — misma base PostgreSQL que Supabase: Settings → Database → Connection string (URI)
# En Windows use el pooler (IPv4). Supabase → Settings → Database → Transaction pooler → URI:
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-1-us-east-1.pooler.supabase.com:6543/postgres
# Opcional alias solo para scripts npm:
# DATABASE_POOLER_URL=postgresql://postgres.[ref]:[password]@aws-1-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Reclutamiento inteligente (Gemini; sesiones en PostgreSQL si DATABASE_URL existe, si no memoria en dev)
GEMINI_API_KEY=
# Modelo para OCR de facturas (por defecto usa gemini-2.5-flash; evite gemini-2.0-flash si da error 429)
# GEMINI_PROCUREMENT_MODEL=gemini-2.5-flash
# Opcional: POST JSON { phone?, sessionId, reason } al cerrar por tiempo o fraude
RECRUITMENT_WHATSAPP_WEBHOOK_URL=

# Protege dashboard CEO y GET /api/recruitment/result/* (Bearer, ?key= o cookie tras POST /api/recruitment/ceo-auth)
RECRUITMENT_CEO_SECRET=

# --- Facturas por Telegram / WhatsApp ---
TELEGRAM_BOT_TOKEN=
# Username del bot sin @ (para enlaces t.me del ingeniero residente)
TELEGRAM_BOT_USERNAME=
TELEGRAM_CHAT_ID=
# Chats autorizados para ENVIAR facturas (IDs separados por coma). Vacío = todos (solo pruebas).
TELEGRAM_ALLOWED_CHAT_IDS=
# true = exige lista blanca aunque no haya filas en BD (combinar con /configuracion/telegram).
TELEGRAM_WHITELIST_ENFORCED=
# true = exige permisos por rol en APIs web (procuras, compras, almacén). Por defecto activo en producción.
# PERMISOS_ENFORCED=true
# Chats del depositario / almacén para alertas de cuarentena (fallback si la obra no tiene enrutamiento).
# Prioridad: depositario de obra + grupo Telegram del proyecto (migr. 201) → empleados alertas_almacen_global → esta variable.
TELEGRAM_ALMACEN_CHAT_IDS=
# Canal o chat para alertas de discrepancia en recepción física (depositario, migr. 209). Fallback: TELEGRAM_ALMACEN_CHAT_IDS.
TELEGRAM_ADMIN_CHANNEL_ID=
# WhatsApp Cloud API (Meta Business)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
# Teléfonos autorizados (solo dígitos, separados por coma). Vacío = todos.
WHATSAPP_ALLOWED_PHONES=

# true = también permitir acceso CEO si hay sesión Supabase (auth.getUser()) además de la clave anterior
RECRUITMENT_ALLOW_SUPABASE_USER=
