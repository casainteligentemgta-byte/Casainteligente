TELEGRAM_BOT_TOKEN=tu_token_de_telegram
GEMINI_API_KEY=tu_api_key_de_gemini

# drive | onedrive | icloud
# STORAGE_PROVIDER=drive
# GEMINI_MODEL=gemini-2.5-flash
# TELEGRAM_ALLOWED_CHAT_IDS=123456789

# Google Drive (OAuth)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=...
GOOGLE_REFRESH_TOKEN=...
# GOOGLE_FOLDER_ID=  (opcional: carpeta destino)

# OneDrive (Microsoft Graph)
MS_CLIENT_ID=...
MS_TENANT_ID=...
MS_CLIENT_SECRET=...
# MS_USER_ID=usuario@tudominio.com  (requerido con client credentials)
# MS_FOLDER_PATH=/CasaInteligente/Asistente

# iCloud (ruta local sincronizada / montaje)
ICLOUD_CONTAINER_PATH=/ruta/a/tu/icloud/local

# Opcional: webhook en vez de polling
# WEBHOOK_DOMAIN=asistente.tudominio.com
# WEBHOOK_PATH=/telegram
# PORT=3001
