# Tokens Principales
TELEGRAM_BOT_TOKEN=tu_token_de_telegram_aqui

# IA: auto | groq | gemini
# auto = usa Groq si hay GROQ_API_KEY; si no, Gemini
AI_PROVIDER=auto

# Groq (gratis): https://console.groq.com/keys
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (cuota free limitada)
GEMINI_API_KEY=tu_api_key_de_gemini_aqui
# GEMINI_MODEL=gemini-2.0-flash

# Opcional: solo estos chats pueden usar el bot (coma-separados)
# TELEGRAM_ALLOWED_CHAT_IDS=267515133

# Credenciales Google Drive
GOOGLE_CLIENT_ID=tu_client_id
GOOGLE_CLIENT_SECRET=tu_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
GOOGLE_REFRESH_TOKEN=tu_refresh_token

# Credenciales OneDrive (Microsoft Graph)
MS_CLIENT_ID=tu_ms_client_id
MS_TENANT_ID=tu_ms_tenant_id
MS_CLIENT_SECRET=tu_ms_client_secret
# MS_USER_ID=

# Configuración iCloud (Ruta local o volumen montado)
ICLOUD_CONTAINER_PATH=/ruta/a/tu/icloud/local
